{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2021"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": false,
    "noEmit": false,
    "emitDeclarationOnly": false,
    "declaration": false,
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/plugins/**/*.ts"],
  "exclude": ["node_modules", "dist", "docs"]
}
