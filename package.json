{
  "name": "@nubisco/ui",
  "version": "1.18.0",
  "description": "Vue 3 UI component library",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nubisco/ui.git"
  },
  "author": "José Silva <jose@nubisco.io>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nubisco/ui/issues"
  },
  "homepage": "https://docs.nubisco.io/ui/",
  "keywords": [
    "vue",
    "vue3",
    "component-library",
    "ui",
    "design-system",
    "typescript",
    "vite"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./dist/ui.css": "./dist/ui.css",
    "./plugins/*": {
      "types": "./dist/plugins/*.d.ts",
      "import": "./dist/plugins/*.js"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./src/components/*"
    },
    "./composables/*": {
      "types": "./dist/composables/*.d.ts",
      "import": "./src/composables/*"
    },
    "./utils/*": {
      "types": "./dist/utils/*.d.ts",
      "import": "./src/utils/*"
    },
    "./styles": "./src/styles/index.scss",
    "./styles/*": "./src/styles/*",
    "./css": "./dist/ui.css",
    "./scss": "./src/styles/index.scss",
    "./variables": "./src/styles/variables/index.scss",
    "./global": {
      "types": "./dist/global.d.ts"
    }
  },
  "files": [
    "dist",
    "src/styles",
    "src/plugins",
    "src/utils",
    "src/assets/icons",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "prebuild": "pnpm run clean",
    "build": "pnpm run build:lib && pnpm run build:types && pnpm run build:plugins",
    "build:lib": "vite build",
    "build:types": "vue-tsc --noEmit false --declaration --emitDeclarationOnly --outDir dist",
    "build:plugins": "tsc --project tsconfig.plugins.json",
    "dev": "vite build --watch",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint --fix src/",
    "types:check": "vue-tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "quality:check": "pnpm run test && pnpm run lint && pnpm run format:check && pnpm run types:check",
    "docs:dev": "vitepress dev docs",
    "docs:build": "node scripts/build-tokens.mjs && vitepress build docs",
    "docs:serve": "vitepress serve docs",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged && pnpm run quality:check",
    "pre-push": "pnpm run quality:check"
  },
  "lint-staged": {
    "src/**/*.{ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "tests/**/*.ts": "prettier --write",
    "*.{json,md,mts,mjs,scss}": "prettier --write"
  },
  "peerDependencies": {
    "vue": "^3.5.30",
    "vue-i18n": "^11.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@phosphor-icons/core": "^2.1.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.1",
    "@vitest/ui": "^4.1.1",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "markdown-it-container": "^4.0.0",
    "mermaid": "^11.13.0",
    "prettier": "^3.8.1",
    "sass-embedded": "^1.98.0",
    "semantic-release": "^25.0.3",
    "simple-git-hooks": "^2.13.1",
    "tinycolor2": "^1.6.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "unplugin-fonts": "^1.4.0",
    "vite": "^8.0.2",
    "vite-svg-loader": "^5.1.1",
    "vitepress": "^1.6.4",
    "vitepress-plugin-group-icons": "^1.7.1",
    "vitest": "^4.1.1",
    "vue": "^3.5.30",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6"
  },
  "release": {
    "branches": [
      "master"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/npm",
      "@semantic-release/github",
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json",
            "CHANGELOG.md"
          ],
          "message": "chore(release): ${nextRelease.version} [skip ci]"
        }
      ]
    ]
  }
}
